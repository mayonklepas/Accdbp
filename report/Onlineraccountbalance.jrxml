	</subDataset>
	<parameter name="DT_FROM" class="java.util.Date"/>
	<parameter name="DT_TO" class="java.util.Date"/>
	<parameter name="ACC_FROM" class="java.lang.String"/>
	<parameter name="ACC_TO" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT ACC_CODE,ACC_NAME,
COALESCE((SELECT SUM(CREDIT) 
	FROM ledgerview 
	WHERE ACC_CODE=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO}
),0) AS CREDIT,
COALESCE((SELECT SUM(DEBIT) 
	FROM ledgerview 
	WHERE ACC_CODE=ta.ACC_CODE 
		AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO}
),0) AS DEBIT
FROM TB_ACC ta 
WHERE ACC_CODE BETWEEN $P{ACC_FROM} AND $P{ACC_TO} 
ORDER BY ACC_CODE]]>
	</queryString>
