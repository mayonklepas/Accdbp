		</field>
		<field name="ACC_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ACC_CODE"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="LEDGERVIEW"/>
