		<parameter name="DT_TO" class="java.util.Date"/>
		<queryString language="SQL">
			<![CDATA[SELECT FIRST 100 * FROM ledgerview WHERE ACC_CODE=$P{ACC_CODE} 
AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} ORDER BY DATE_TRANS]]>
		</queryString>
