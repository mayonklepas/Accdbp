	<parameter name="DT_FROM" class="java.util.Date"/>
	<parameter name="DT_TO" class="java.util.Date"/>
	<parameter name="COMPANY_NAME" class="java.lang.String"/>
	<parameter name="COMPANY_ADDRESS" class="java.lang.String"/>
	<parameter name="COMPANY_TELEPHONE" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT ACC_CODE,ACC_NAME,

CASE WHEN (SELECT COUNT(*) FROM BALANCESET WHERE  DATE_TRANS BETWEEN $P{DT_FROM}  AND $P{DT_TO} ) = 0 THEN

ACC_OPENING_BALANCE


ELSE

CASE WHEN ISBOOKPRINT=0 THEN 


CASE WHEN  (SELECT DATE_TRANS FROM BALANCESET ORDER BY ID DESC FETCH FIRST 1 ROWS ONLY) <= $P{DT_TO} THEN 
ACC_CURRENT_BALANCE 
ELSE COALESCE((SELECT SALDO FROM BALANCESET WHERE ACC_CODE=ta.ACC_CODE AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} ORDER BY ID FETCH FIRST 1 ROWS ONLY),0) END


ELSE 



CASE WHEN  (SELECT DATE_TRANS FROM BALANCESET ORDER BY ID DESC FETCH FIRST 1 ROWS ONLY ) <=$P{DT_TO} THEN 
ACC_CURRENT_BALANCE 
ELSE COALESCE((SELECT SALDO_MASTER FROM BALANCESET WHERE ACC_CODE_MASTER=ta.ACC_CODE  AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} ORDER BY ID DESC FETCH FIRST 1 ROWS ONLY ),0) END

END END AS AMOUNT


FROM 
TB_ACC ta 
ORDER BY ACC_CODE ASC]]>
	</queryString>
