	<subDataset name="profitloss" uuid="323bf07b-3add-400e-a744-890604b42568">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="accdb"/>
		<queryString language="SQL">
			<![CDATA[SELECT ACC_CODE,ACC_NAME,ACC_GROUP,
COALESCE((SELECT SUM(CREDIT) 
	FROM ledgerview 
	WHERE ACC_CODE=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN '01.01.2019' AND '27.07.2019'
),0) AS CREDIT,
COALESCE((SELECT SUM(DEBIT) 
	FROM ledgerview 
	WHERE ACC_CODE=ta.ACC_CODE 
		AND DATE_TRANS BETWEEN '01.01.2019' AND '27.07.2019'
),0) AS DEBIT
FROM TB_ACC ta WHERE ACC_GROUP=0 OR ACC_GROUP=2]]>
		</queryString>
		<field name="ACC_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ACC_CODE"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="TB_ACC"/>
		</field>
		<field name="ACC_NAME" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ACC_NAME"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="TB_ACC"/>
		</field>
		<field name="ACC_GROUP" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.label" value="ACC_GROUP"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="TB_ACC"/>
		</field>
		<field name="CREDIT" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.label" value="CREDIT"/>
		</field>
		<field name="DEBIT" class="java.lang.Double">
			<property name="com.jaspersoft.studio.field.label" value="DEBIT"/>
		</field>
		<variable name="CREDIT1" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{CREDIT}]]></variableExpression>
		</variable>
		<variable name="DEBIT1" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{DEBIT}]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="balancesheet" uuid="3d1f85dc-42c6-47fa-881d-950acfbaa1c7">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="accdb"/>
		<queryString language="SQL">
			<![CDATA[SELECT ACC_CODE,ACC_NAME,ACC_GROUP,
COALESCE((SELECT SUM(CREDIT) 
	FROM ledgerview 
	WHERE ACC_CODE=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN '01.01.2019' AND '27.07.2019'
),0) AS CREDIT,
COALESCE((SELECT SUM(DEBIT) 
	FROM ledgerview 
	WHERE ACC_CODE=ta.ACC_CODE 
		AND DATE_TRANS BETWEEN '01.01.2019' AND '27.07.2019'
),0) AS DEBIT
FROM TB_ACC ta WHERE ACC_GROUP=1 OR ACC_GROUP=3]]>
		</queryString>
		<field name="ACC_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ACC_CODE"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="TB_ACC"/>
