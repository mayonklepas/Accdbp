	<parameter name="DT_FROM" class="java.util.Date"/>
	<parameter name="DT_TO" class="java.util.Date"/>
	<parameter name="COMPANY_NAME" class="java.lang.String"/>
	<parameter name="COMPANY_ADDRESS" class="java.lang.String"/>
	<parameter name="COMPANY_TELEPHONE" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT ACC_CODE,ACC_NAME,ISBOOKPRINT,
CASE WHEN 
(CASE WHEN ISBOOKPRINT=0 THEN
(SELECT SALDO
	FROM ALLTRANS
	WHERE ACC_CODE=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} LIMIT 1 )
	ELSE (SELECT SALDO_MASTER
	FROM ALLTRANS
	WHERE ACC_CODE=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO}  LIMIT 1) END)>0 
	THEN 0 ELSE 

(CASE WHEN ISBOOKPRINT = 0
THEN
COALESCE((SELECT FIRST 1 SALDO
	FROM ALLTRANS
	WHERE ACC_CODE=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} 
	AND SALDO > 0 ORDER BY ID DESC
),0)  ELSE COALESCE((SELECT FIRST 1 SALDO_MASTER
	FROM ALLTRANS
	WHERE ACC_CODE_MASTER=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} 
	AND SALDO_MASTER > 0 ORDER BY ID DESC
),0) END) END AS DEBIT,
CASE WHEN ISBOOKPRINT = 0
THEN
COALESCE((SELECT SALDO
	FROM ALLTRANS
	WHERE ACC_CODE=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} 
	AND SALDO < 0 ORDER BY ID DESC
 LIMIT 1),0)  ELSE COALESCE((SELECT SALDO_MASTER
	FROM ALLTRANS
	WHERE ACC_CODE_MASTER=ta.ACC_CODE 
	AND DATE_TRANS BETWEEN $P{DT_FROM} AND $P{DT_TO} 
	AND SALDO_MASTER < 0 ORDER BY ID DESC
 LIMIT 1 ),0) END AS CREDIT
FROM TB_ACC ta WHERE ACC_GROUP=1 OR ACC_GROUP=3]]>
	</queryString>
